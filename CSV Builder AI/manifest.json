{
  "manifest_version": 3,
  "name": "Multi-Platform Scraper Engine",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
  "https://*/*",
  "http://*/*"
],
"content_scripts": [
  {
    "matches": ["https://*/*", "http://*/*"],
    "js": ["src/content/engine.js"],
    "run_at": "document_idle"
  }
],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html"
}
